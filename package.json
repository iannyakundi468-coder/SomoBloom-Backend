{
  "name": "somobloom-backend",
  "version": "1.0.0",
  "description": "SomoBloom serverless backend on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'No build step required for Workers'",
    "deploy": "wrangler deploy --minify",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply somobloom_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply somobloom_db --remote",
    "db:migrate:staging": "wrangler d1 migrations apply somobloom_db_staging --remote --env staging",
    "db:seed": "node scripts/seed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/ai": "^1.2.2",
    "drizzle-orm": "^0.36.3",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.90.1"
  }
}
